rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidHeartfeltNote(data) {
      return data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.sender is string && data.sender.size() > 0 && data.sender.size() <= 50 &&
             data.color is string &&
             data.createdAt is string &&
             data.rotation is number;
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    match /heartfeltNotes/{noteId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(noteId) && isValidHeartfeltNote(request.resource.data);
      allow delete: if isSignedIn();
    }
  }
}
